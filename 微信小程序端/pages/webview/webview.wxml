<!-- pages/webview/webview.wxml -->

<view class="container">
  <view class="card">
    <!-- --- 修改：不再引用本地图片，而是直接使用Base64内联SVG图标 --- -->
    <!-- 这样做可以确保图标永远不会加载失败 -->
    <image class="icon" src="data:image/svg+xml;base64,"></image>
    
    <view class="title">无法直接打开页面</view>
    <view class="description">由于平台限制，请复制链接后，在手机浏览器中粘贴并打开查看。</view>
    
    <view class="url-box">
      <text class="url-text" selectable="true">{{url}}</text>
    </view>
    
    <button class="copy-btn" bindtap="copyUrl">一键复制链接</button>

    <view class="steps">
        <view class="step-item">1. 点击上方按钮复制链接</view>
        <view class="step-item">2. 退出小程序，打开手机浏览器</view>
        <view class="step-item">3. 在浏览器地址栏粘贴并访问</view>
    </view>
  </view>
</view>

