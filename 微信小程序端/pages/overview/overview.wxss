/* pages/overview/overview.wxss */
.page-container {
    padding: 36rpx;
    background-color: #f7f8fa;
    min-height: 100vh;
    box-sizing: border-box;
}
  
.header-title-wrapper {
  display: flex;
  align-items: center;
  margin-bottom: 36rpx;
}
  
.header-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
}
  
.header-logo-inline {
  height: 80rpx;
  margin-left: 35rpx;
}
  
.device-grid {
  display: grid;
  grid-template-columns: 1fr;
  grid-gap: 32rpx;
}
  
.device-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s;
}
  
.device-card:active {
  transform: scale(0.98);
}
  
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
  
.device-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}
  
.device-status {
  font-size: 26rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: bold;
}
  
.device-status.online {
  background-color: #e6f7f2;
  color: #28a745;
}
  
.device-status.offline {
  background-color: #fdeaea;
  color: #dc3545;
}
  
.update-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
  
.card-body {
  margin-top: 24rpx;
}
  
.data-group {
  margin-bottom: 20rpx;
}
.data-group:last-child {
  margin-bottom: 0;
}
  
.data-group-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #555;
  margin-bottom: 24rpx;
}
  
.sensor-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-gap: 20rpx;
}
  
.sensor-item {
  display: flex;
  align-items: center;
  background-color: #f7f8fa;
  border-radius: 12rpx;
  padding: 16rpx;
}
  
.sensor-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}
  
.sensor-text {
  display: flex;
  flex-direction: column;
}
  
.sensor-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.2;
}
  
.sensor-label {
  font-size: 24rpx;
  color: #666;
}
  
.unit {
  font-size: 24rpx;
  font-weight: normal;
  color: #666;
}
  
.loading-container, .empty-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  color: #999;
  font-size: 28rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e2e8f0;
  border-top-color: #3d7ef9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
  
.sensor-value.abnormal {
  color: #fa5151;
  font-weight: bold;
}

/* --- 新增：数据网站跳转按钮样式 --- */
.data-link-button {
  margin-top: 32rpx; /* 与上方内容的间距 */
  padding: 20rpx;
  background-color: #f7f8fa; /* 使用页面背景色作为底色 */
  border-top: 1rpx solid #f0f0f0; /* 添加一个顶部分割线 */
  text-align: center;
  font-size: 28rpx;
  color: #3d7ef9; /* 使用主题蓝色 */
  font-weight: bold;
  cursor: pointer;
  transition: background-color 0.2s;
  /* 使用负边距让按钮撑满卡片宽度并贴合底部 */
  margin-left: -32rpx;
  margin-right: -32rpx;
  margin-bottom: -32rpx;
  /* 调整圆角以匹配卡片底部 */
  border-bottom-left-radius: 20rpx;
  border-bottom-right-radius: 20rpx;
}

.data-link-button:active {
  background-color: #e9ebee; /* 点击时的背景色变化 */
}