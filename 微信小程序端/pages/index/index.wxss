/* pages/index/index.wxss */

.page-container { padding: 36rpx; background-color: #f7f8fa; min-height: 100vh; box-sizing: border-box; }
.header-container { background: linear-gradient(135deg, #4a90e2 0%, #3d7ef9 100%);
color: #fff; border-radius: 24rpx; padding: 32rpx 48rpx; box-shadow: 0 8rpx 16rpx rgba(61, 126, 249, 0.2);
margin-bottom: 36rpx;}
.header-container .header-2 { font-size: 48rpx; font-weight: bold; text-align: center; }
.container-title { font-size: 32rpx; font-weight: bold; color: #333; margin-top: 48rpx;
margin-bottom: 24rpx; padding-left: 10rpx; }
.data-grid-container { display: grid; grid-template-columns: repeat(auto-fill, minmax(310rpx, 1fr)); grid-gap: 24rpx; }
.data-item { position: relative; background-color: #fff;
height: 180rpx; box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05); border-radius: 20rpx; display: flex; flex-direction: column; justify-content: center; padding: 24rpx;
box-sizing: border-box; }
.data-item .data-content { display: flex; align-items: center; }
.data-item .data-picture { height: 64rpx; width: 64rpx; margin-right: 24rpx;
}
.data-item .data-text { white-space: nowrap; }
.data-item .data-title { font-size: 28rpx; color: #666; }
.data-item .data-value { font-size: 48rpx; font-weight: bold;
color: #333; margin-top: 8rpx; }
.control-panel { background-color: #ffffff; border-radius: 20rpx; padding: 32rpx; box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}
.motor-group { margin-bottom: 48rpx; }
.motor-group:last-child { margin-bottom: 0; }

.motor-title-container {
  display: flex;
  justify-content: space-between;
align-items: center;
  margin-bottom: 24rpx;
}

.motor-title { font-size: 28rpx; font-weight: bold; color: #333; }

.status-indicators {
  display: flex;
align-items: center;
  gap: 16rpx;
}

.motor-running-status {
  font-size: 24rpx;
  font-weight: bold;

  padding: 6rpx 18rpx; 
  border-radius: 8rpx;
  color: #fff;
}
/* 【修改】匹配 1,2,3,4 状态 */
.running-state-unknown { background-color: #909399; }
.running-state-1 { background-color: #1989fa; } /* 运行中(开) */
.running-state-2 { background-color: #6c757d; } /* 已停止(开) */
.running-state-3 { background-color: #1989fa; } /* 运行中(关) */
.running-state-4 { background-color: #6c757d; } /* 已停止(关) */


.motor-command-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
color: #fff;
}
.status-idle { background-color: #c9c9c9; }
.status-pending { background-color: #f9ae3d; } /* (此状态不再使用，但保留) */
.status-success { background-color: #28a745; } /* (代表 isRunning = true) */
.status-error { background-color: #dc3545;
}

.duration-input-group { display: flex; align-items: center; margin-bottom: 24rpx; background-color: #f7f8fa; border-radius: 12rpx; padding: 16rpx 24rpx;
}
.input-label { font-size: 28rpx;
color: #666; margin-right: 20rpx; }
.duration-input { flex: 1; font-size: 32rpx; font-weight: bold; color: #333; text-align: right;
}
.button-grid { display: grid;
grid-template-columns: 1fr 1fr; grid-gap: 20rpx; 
    margin-bottom: 16rpx; 
}
.btn { height: 80rpx; line-height: 80rpx;
text-align: center;
border-radius: 12rpx; font-size: 28rpx;
color: #fff; transition: background-color 0.3s; }
.progress-bar { width: 100%; }
.btn.disabled { background-color: #c8c9cc !important;
pointer-events: none;
}
.btn-open { background-color: #28a745;
}
.btn-close { background-color: #888888; }

.progress-labels {
  display: flex;
  justify-content: space-between;
font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
/* 调整标签和百分比之间的间距 */
  padding: 0 4rpx;
}

.progress-percentage {
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
margin-bottom: 8rpx; /* 调整百分比和进度条之间的间距 */
}

.calibrate-controls {
  display: flex;
  justify-content: space-around;
  margin-top: 16rpx;
}
.calibrate-btn {
  font-size: 24rpx;
  color: #3d7ef9;
padding: 8rpx 16rpx;
  border: 1px solid #3d7ef9;
  border-radius: 8rpx;
}

/* --- 【新增】--- */
/* 用于在"环境数据监测"中显示长文本状态，而不会破坏布局 */
.data-item .data-value.data-value-small {
  font-size: 32rpx; /* 字体缩小 */
  font-weight: bold; /* 保持粗体 */
  white-space: normal; /* 允许换行 */
  line-height: 1.3; /* 调整行高 */
  /* 调整 data-text 的 white-space 以便 data-title 正常显示 */
  /* (经检查, data-text 已有 white-space: nowrap, 这很好, 
     但 data-value 需要覆盖它) */
  white-space: normal; 
}
/* --- 【新增结束】--- */